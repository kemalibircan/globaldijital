# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=production
HOST=0.0.0.0

# CORS — add your Railway frontend URL here (comma-separated for multiple)
# Example: https://globaldijital-frontend.up.railway.app
CORS_ORIGIN=https://your-frontend.up.railway.app

# PostgreSQL — Railway otomatik olarak DATABASE_URL sağlar (PostgreSQL eklentisi eklenince)
# Railway'de bu değeri kendiniz girmenize gerek YOK, otomatik inject edilir.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=your-strong-random-secret-here

# OpenAI (Glob AI Chat)
OPENAI_API_KEY=sk-proj-...
OPENAI_CHAT_MODEL=gpt-4o-mini
